# ==================================================
# StoryForge Environment Configuration
# Copy this file to ".env" and replace the values.
# ==================================================

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Application
APP_TITLE=StoryForge
APP_VERSION=1.0.0

# AI Generation
MAX_OUTPUT_TOKENS=4096
TEMPERATURE=0.85

# Gemini Rate Limits
GEMINI_RPM_LIMIT=15
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RETRY_DELAY_BASE=4.0
GEMINI_SEQUENTIAL_DELAY=2.5

# Database
DB_PATH=outputs/iac_stories.db

# Reports
REPORTS_DIR=reports